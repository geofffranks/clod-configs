# Copy to ~/.config/polytoken-container.env and fill in.
# Passed into the container via --env-file at launch. NEVER baked into the image.
#
# Add whatever provider keys your Polytoken providers read from the environment:

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Examples of others you might need:
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# BRAVE_SEARCH_API_KEY=
# TAVILY_API_KEY=
